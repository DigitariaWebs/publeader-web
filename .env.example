# Copy to .env.local and fill in values.

# Site URL (used for redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default UI style on first visit — "glass" or "pro"
NEXT_PUBLIC_DEFAULT_UI_STYLE=glass

# Default dashboard variant when uiStyle=pro — "glass" or "pro"
NEXT_PUBLIC_DEFAULT_DASHBOARD_STYLE=glass

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-long-random-string

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=driveads

# SMTP (leave empty in dev to log OTP to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@driveads.local

# Admin seed
ADMIN_EMAIL=admin@driveads.local
ADMIN_PASSWORD=admin123!
ADMIN_NAME=Admin
